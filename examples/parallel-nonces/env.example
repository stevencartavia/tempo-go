# Tempo RPC endpoint
TEMPO_RPC_URL=https://rpc.testnet.tempo.xyz

# Optional: RPC authentication (if required)
TEMPO_RPC_USERNAME=
TEMPO_RPC_PASSWORD=

# Your private key (required)
TEMPO_PRIVATE_KEY=0x...

# Chain ID (default: 42429 for testnet)
TEMPO_CHAIN_ID=42429

# Recipient address for the parallel transfers (required)
TEMPO_RECIPIENT_ADDRESS=0x...
